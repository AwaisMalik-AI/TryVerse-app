{
  "expo": {
    "name": "TryVerse",
    "slug": "tryverse",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "tryverse",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.xvantech.tryverse",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "TryVerse needs camera access to take selfies for virtual try-on",
        "NSPhotoLibraryUsageDescription": "TryVerse needs photo library access to select photos for virtual try-on"
      }
    },
    "android": {
      "package": "com.xvantech.tryverse",
      "versionCode": 3,
      "adaptiveIcon": {
        "backgroundColor": "#1a1a2e",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.INTERNET",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "TryVerse needs access to your photos for virtual try-on.",
          "cameraPermission": "TryVerse needs access to your camera to take selfies."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#1a1a2e"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "c5264b24-7574-4397-8c06-74f6b631e88c"
      },
      "router": {}
    },
    "owner": "awais_malik"
  }
}
